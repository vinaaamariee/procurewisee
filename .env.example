# Transaction Pooler URL (recommended for serverless environments / Next.js)
# Supabase settings -> Database -> Connection string -> URI -> Mode: Transaction (Port 6543)
# Note the addition of `?pgbouncer=true&connection_limit=1` parameters at the end.
DATABASE_URL="postgresql://postgres.tfswokhkuxwvpcpxekso:73NjFynhhv6cbnwj@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres"

# Direct URL (used by Prisma for migrations, schemas, and direct schema updates - Port 5432)
# Supabase settings -> Database -> Connection string -> URI -> Mode: Session (or Transaction if direct pooler is not needed, but direct port 5432 is preferred)
DIRECT_URL="postgresql://postgres.tfswokhkuxwvpcpxekso:73NjFynhhv6cbnwj@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

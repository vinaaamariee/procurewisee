// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Supplier {
  id        String       @id
  name      String
  location  String
  contact   String
  rating    Float
  quotes    PriceQuote[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model OfficeItem {
  id          String       @id
  name        String
  unit        String
  category    String
  description String
  quotes      PriceQuote[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model PriceQuote {
  id           String     @id @default(uuid())
  supplierId   String
  supplier     Supplier   @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  itemId       String
  item         OfficeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  unitPrice    Float
  availability String     // "in-stock" | "limited" | "out-of-stock"
  deliveryDays Int
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([supplierId, itemId])
}

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ProcurementOfficer     @map("Procurement Officer")
  Supplier               @map("Supplier")
  AdministrativeApprover @map("Administrative Approver")
}

enum RfqStatus {
  Draft
  Published
  Closed
  Evaluated
}

enum QuoteStatus {
  Submitted
  UnderReview @map("Under Review")
  Accepted
  Rejected
}

// ─────────────────────────────────────────────────────────────────────────────
// 1. USER PROFILES (extends Supabase auth.users — no password_hash stored here)
// ─────────────────────────────────────────────────────────────────────────────

model UserProfile {
  id        String   @id // UUID — must match auth.users.id from Supabase Auth
  username  String   @unique @db.VarChar(50)
  fullName  String   @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  role      UserRole
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relations
  appItemsCreated         AppItem[]         @relation("AppItemCreatedBy")
  rfqsCreated             RequestForQuote[] @relation("RfqCreatedBy")
  canvasesCompiled        CanvasAbstract[]  @relation("CanvasCompiledBy")
  recommendationsReviewed Recommendation[]  @relation("RecommendationReviewedBy")
  auditTrails             AuditTrail[]

  @@map("user_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// 2. REGISTERED SUPPLIERS
// ─────────────────────────────────────────────────────────────────────────────

model Supplier {
  id                     Int      @id @default(autoincrement()) @map("supplier_id")
  companyName            String   @db.VarChar(150)
  tin                    String?  @unique @db.VarChar(15)
  contactPerson          String?  @db.VarChar(100)
  contactNumber          String?  @db.VarChar(20)
  businessAddress        String
  reliabilityRating      Decimal  @default(5.00) @db.Decimal(3, 2)
  qualityComplianceRate  Decimal  @default(100.00) @db.Decimal(5, 2)
  historicalDeliveryDays Int      @default(0)
  isVerified             Boolean  @default(false)
  createdAt              DateTime @default(now())

  // Relations
  quotes          SupplierQuote[]
  recommendations Recommendation[]

  @@map("suppliers")
}

// ─────────────────────────────────────────────────────────────────────────────
// 3. ANNUAL PROCUREMENT PLAN (APP) ITEMS
// ─────────────────────────────────────────────────────────────────────────────

model AppItem {
  id                 Int          @id @default(autoincrement()) @map("app_item_id")
  papCode            String       @db.VarChar(50)
  objectCode         String?      @db.VarChar(50)
  projectTitle       String       @db.VarChar(255)
  endUserUnit        String       @db.VarChar(100)
  generalDescription String
  modeOfProcurement  String       @default("Small Value Procurement") @db.VarChar(100)
  sourceOfFund       String       @db.VarChar(100)
  estimatedBudget    Decimal      @db.Decimal(12, 2)
  fyYear             Int          @default(2026)
  createdById        String? // FK → UserProfile.id (UUID)
  createdBy          UserProfile? @relation("AppItemCreatedBy", fields: [createdById], references: [id])

  // Relations
  rfqItems RfqItem[]

  @@map("app_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// 4. REQUESTS FOR QUOTATION (RFQ MASTER)
// ─────────────────────────────────────────────────────────────────────────────

model RequestForQuote {
  id                     Int          @id @default(autoincrement()) @map("rfq_id")
  rfqNumber              String       @unique @db.VarChar(50)
  title                  String       @db.VarChar(255)
  approvedBudgetContract Decimal      @db.Decimal(12, 2)
  deadlineDate           DateTime     @db.Date
  status                 RfqStatus    @default(Draft)
  createdById            String? // FK → UserProfile.id (UUID)
  createdBy              UserProfile? @relation("RfqCreatedBy", fields: [createdById], references: [id])
  createdAt              DateTime     @default(now())

  // Relations
  items           RfqItem[]
  quotes          SupplierQuote[]
  canvasAbstracts CanvasAbstract[]

  @@map("requests_for_quote")
}

// ─────────────────────────────────────────────────────────────────────────────
// 5. RFQ ITEM REQUISITION DETAILS
// ─────────────────────────────────────────────────────────────────────────────

model RfqItem {
  id          Int             @id @default(autoincrement()) @map("rfq_item_id")
  rfqId       Int
  rfq         RequestForQuote @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  appItemId   Int?
  appItem     AppItem?        @relation(fields: [appItemId], references: [id])
  itemNumber  String          @db.VarChar(10)
  particulars String
  quantity    Int
  unit        String          @db.VarChar(20)

  // Relations
  quoteDetails QuoteDetail[]

  @@map("rfq_items")
}

// ─────────────────────────────────────────────────────────────────────────────
// 6. SUPPLIER QUOTATION SUBMISSIONS
// ─────────────────────────────────────────────────────────────────────────────

model SupplierQuote {
  id                  Int             @id @default(autoincrement()) @map("quote_id")
  rfqId               Int
  rfq                 RequestForQuote @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplierId          Int
  supplier            Supplier        @relation(fields: [supplierId], references: [id])
  submissionDate      DateTime        @default(now()) @db.Date
  totalQuotedAmount   Decimal         @db.Decimal(12, 2)
  offeredDeliveryDays Int
  status              QuoteStatus     @default(Submitted)

  // Relations
  quoteDetails    QuoteDetail[]
  recommendations Recommendation[]

  @@map("supplier_quotes")
}

// ─────────────────────────────────────────────────────────────────────────────
// 7. QUOTATION LINE-ITEM BREAKDOWN
// Note: totalPrice is computed in application logic (quantity_multiplier * unit_price)
// Prisma does not support GENERATED ALWAYS AS — computed at query time instead.
// ─────────────────────────────────────────────────────────────────────────────

model QuoteDetail {
  id                 Int           @id @default(autoincrement()) @map("detail_id")
  quoteId            Int
  quote              SupplierQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  rfqItemId          Int
  rfqItem            RfqItem       @relation(fields: [rfqItemId], references: [id])
  unitPrice          Decimal       @db.Decimal(12, 2)
  quantityMultiplier Int           @default(1)
  isAvailable        Boolean       @default(true)

  @@map("quote_details")
}

// ─────────────────────────────────────────────────────────────────────────────
// 8. CANVAS ABSTRACTS
// ─────────────────────────────────────────────────────────────────────────────

model CanvasAbstract {
  id             Int             @id @default(autoincrement()) @map("canvas_id")
  rfqId          Int
  rfq            RequestForQuote @relation(fields: [rfqId], references: [id])
  openingDate    DateTime        @default(now()) @db.Date
  locationOpened String          @default("Basco, Batanes") @db.VarChar(100)
  compiledById   String? // FK → UserProfile.id (UUID)
  compiledBy     UserProfile?    @relation("CanvasCompiledBy", fields: [compiledById], references: [id])

  // Relations
  recommendations Recommendation[]

  @@map("canvas_abstracts")
}

// ─────────────────────────────────────────────────────────────────────────────
// 9. BEST-VALUE MACHINE RECOMMENDATIONS (MCDM Output)
// ─────────────────────────────────────────────────────────────────────────────

model Recommendation {
  id                 Int            @id @default(autoincrement()) @map("recomm_id")
  canvasId           Int
  canvas             CanvasAbstract @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  supplierId         Int
  supplier           Supplier       @relation(fields: [supplierId], references: [id])
  supplierQuoteId    Int
  supplierQuote      SupplierQuote  @relation(fields: [supplierQuoteId], references: [id])
  compositeMcdmScore Decimal        @db.Decimal(5, 2)
  priceScore         Decimal        @db.Decimal(5, 2)
  deliveryScore      Decimal        @db.Decimal(5, 2)
  reliabilityScore   Decimal        @db.Decimal(5, 2)
  rankPosition       Int
  justificationLog   String
  approverRemarks    String?
  approvalStatus     String         @default("Pending Review") @db.VarChar(30)
  reviewedById       String? // FK → UserProfile.id (UUID)
  reviewedBy         UserProfile?   @relation("RecommendationReviewedBy", fields: [reviewedById], references: [id])

  @@map("recommendations")
}

// ─────────────────────────────────────────────────────────────────────────────
// 10. IMMUTABLE SECURITY AUDIT TRAIL
// ─────────────────────────────────────────────────────────────────────────────

model AuditTrail {
  id            Int          @id @default(autoincrement()) @map("audit_id")
  userId        String? // FK → UserProfile.id (UUID)
  user          UserProfile? @relation(fields: [userId], references: [id])
  actionType    String       @db.VarChar(50)
  tableAffected String       @db.VarChar(50)
  recordId      Int
  oldState      Json?
  newState      Json?
  ipAddress     String?      @db.VarChar(45)
  timestamp     DateTime     @default(now())

  @@map("audit_trails")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEGACY — kept for Price Comparison Dashboard compatibility
// ─────────────────────────────────────────────────────────────────────────────

model OfficeItem {
  id          String       @id
  name        String
  unit        String
  category    String
  description String
  quotes      PriceQuote[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model PriceQuote {
  id           String     @id @default(uuid())
  supplierId   String
  itemId       String
  item         OfficeItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  unitPrice    Float
  availability String
  deliveryDays Int
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([supplierId, itemId])
}
